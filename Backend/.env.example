# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Option 1: Local MongoDB (requires MongoDB installation)
MONGO_URI=mongodb://localhost:27017/college-datesheet-portal

# Option 2: MongoDB Atlas (cloud) - comment out local and use this instead
# Get connection string from: https://www.mongodb.com/cloud/atlas
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/college-datesheet-portal

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend/Login URL used in account emails
FRONTEND_URL=http://localhost:5173
LOGIN_URL=http://localhost:5173

# Super Admin SMTP email configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=superadmin@example.com
SMTP_PASS=your_smtp_app_password
SMTP_FROM=superadmin@example.com

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=eawvpwvn
CLOUDINARY_API_KEY=427571491493398
CLOUDINARY_API_SECRET=f4RsZhZVqXAYi1Ul1J6ZEbgmdEE

# Redis Configuration (for Bull Queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
