# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Option 1: Local MongoDB (requires MongoDB installation)
MONGO_URI=mongodb://localhost:27017/college-datesheet-portal

# Option 2: MongoDB Atlas (cloud) - comment out local and use this instead
# Get connection string from: https://www.mongodb.com/cloud/atlas
# MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/college-datesheet-portal

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Redis Configuration (for Bull Queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
